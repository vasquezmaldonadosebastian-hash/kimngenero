NODE_ENV=development
PORT=3000
INDICATOR_REPOSITORY=memory
# Use only when INDICATOR_REPOSITORY=sqlite
SQLITE_DB_PATH=data/indicators.sqlite
# Optional allowlist for embedded dashboards
IFRAME_ALLOWLIST=https://app.powerbi.com,https://public.tableau.com
# Set to false only after validating dashboards in production
CSP_REPORT_ONLY=true
